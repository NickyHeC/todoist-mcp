# =============================================================================
# Environment Variables for MCP Server
# =============================================================================
# Only fill in the variables for the auth framework you chose.
# See README.md > "Choose Your Auth Framework" for guidance.
#
# Copy this file:  cp .env.example .env
# Then fill in the values below.

# =============================================================================
# Dedalus Platform (required for API Key and OAuth — not needed for No Auth)
# =============================================================================

DEDALUS_AS_URL=https://as.dedaluslabs.ai
DEDALUS_API_KEY=
DEDALUS_API_URL=https://api.dedaluslabs.ai

# =============================================================================
# API Key Auth
# =============================================================================
# The credential for your target platform. Rename to match your platform's
# token name (e.g. GITHUB_TOKEN, SLACK_TOKEN, DISCORD_BOT_TOKEN).
# Must match the SecretKeys(token="...") value in src/main.py.

API_TOKEN=

# =============================================================================
# OAuth Auth — Platform Token
# =============================================================================
# The token name DAuth will provide after OAuth exchange.
# Must match the SecretKeys(token="...") value in src/main.py.

ACCESS_TOKEN=

# =============================================================================
# OAuth Auth
# =============================================================================
# These variables configure the OAuth flow on the Dedalus platform.
# IMPORTANT: These must be baked into the server environment at deploy time.
# The Dedalus platform reads them to handle the OAuth token exchange —
# your Python server code does not consume them directly.

OAUTH_ENABLED=true
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES_AVAILABLE=
OAUTH_BASE_URL=
